server {
    listen 80;
    server_name localhost;

    # Serve static assets
    location / {
        root /usr/share/nginx/html;
        index index.html index.htm;
        try_files $uri $uri/ /index.html;
    }

    # Internal proxy is removed. 
    # Use your edge proxy (Caddy/Nginx/Traefik) to route /socket.io/ 
    # directly to the backend container.
}
